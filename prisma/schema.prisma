generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model barbers {
  id            String         @id
  name          String
  role          String
  rating        Float          @default(5.0) @db.Real
  reviewscount  Int            @default(0)
  bio           String
  image         String
  status        String         @default("active")
  availabledays String
  reservations  reservations[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model comments {
  id        String   @id @default(uuid())
  userId    String
  comment   String
  rating    Int
  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @default(now()) @map("updatedat")

  user users @relation(fields: [userId], references: [id])
}


/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reservations {
  id        String   @id @default(uuid())
  userId    String   @map("userid")
  serviceId String   @map("serviceid")
  barberId  String   @map("barberid")
  date      DateTime @db.Date
  time      DateTime @db.Time(6)
  price     Float    @db.Real
  status    String   @default("pending")
  createdat DateTime @default(now()) @db.Timestamptz(6)
  updatedat DateTime @default(now()) @db.Timestamptz(6)
  barbers   barbers  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  services  services @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model services {
  id           String         @id
  name         String
  description  String
  price        Float          @db.Real
  duration     Int
  category     String
  reservations reservations[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                  String   @id @default(uuid())
  name                String?
  email               String?  @unique
  password            String?
  phone               String?
  address             String?
  role                String   @default("cliente")
  image               String?
  needsPasswordChange Boolean  @default(false) @map("needsPasswordChange")
  createdAt           DateTime @default(now()) @map("createdat")
  updatedAt           DateTime @default(now()) @map("updatedat")

  comments     comments[]
  reservations reservations[]
}
